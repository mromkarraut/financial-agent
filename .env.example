# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Comma-separated chat IDs to restrict the bot (leave empty to allow all chats).
# Channel IDs are typically negative, e.g. -1001234567890
TELEGRAM_CHANNEL_ID=

# ── LM Studio ─────────────────────────────────────────────────────────────────
# Enable: LM Studio → Developer tab → Start Server (default port 1234).
# Set LLM_MODEL to exactly the model name shown in LM Studio's model selector.
# Tool/function calling requires a compatible model (Llama-3, Qwen2.5, Mistral-Nemo, etc.)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LLM_MODEL=local-model
LLM_MAX_TOKENS=2048
LLM_ORCHESTRATOR_MAX_TOKENS=1024

# ── Data providers ────────────────────────────────────────────────────────────
# Optional — enables real-time Polygon.io quotes on top of yfinance.
POLYGON_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=db/state.db

# ── Behaviour ─────────────────────────────────────────────────────────────────
LONG_MESSAGE_THRESHOLD=300
